{
  "dashboard": {
    "id": null,
    "uid": "dal-overview",
    "title": "DAL Overview",
    "tags": ["dal", "grpc"],
    "timezone": "browser",
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "gRPC Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(dal_grpc_requests_total[5m])) by (method)",
            "legendFormat": "{{method}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 2,
        "title": "gRPC Latency (P50 / P95 / P99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(dal_grpc_request_duration_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "P50 {{method}}"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(dal_grpc_request_duration_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "P95 {{method}}"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(dal_grpc_request_duration_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "P99 {{method}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 3,
        "title": "Cache Hit Rate",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(dal_cache_hits_total[5m])) / (sum(rate(dal_cache_hits_total[5m])) + sum(rate(dal_cache_misses_total[5m])))",
            "legendFormat": "Hit Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.5 },
                { "color": "green", "value": 0.8 }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Cache Hits vs Misses",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(dal_cache_hits_total[5m])) by (service, entity)",
            "legendFormat": "Hit {{service}}/{{entity}}"
          },
          {
            "expr": "sum(rate(dal_cache_misses_total[5m])) by (service, entity)",
            "legendFormat": "Miss {{service}}/{{entity}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 5,
        "title": "Kafka Produce Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(dal_kafka_produce_total[5m])) by (topic)",
            "legendFormat": "{{topic}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      }
    ]
  }
}
