{
  "name": "@tarot/backend",
  "version": "1.0.0",
  "description": "AI Tarot Friend - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:debug": "tsx watch --inspect src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "migration:run": "tsx src/scripts/migrate.ts up",
    "migration:generate": "tsx src/scripts/migrate.ts generate",
    "migration:revert": "tsx src/scripts/migrate.ts down",
    "seed": "tsx src/scripts/seed-all.ts",
    "db:reset": "tsx src/scripts/reset-db.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.46.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.206.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.206.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-metrics": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "@prisma/client": "^5.9.1",
    "@types/cors": "^2.8.19",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "openai": "^4.28.0",
    "pg": "^8.16.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "stripe": "^14.14.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@vitest/coverage-v8": "^1.2.1",
    "eslint": "^8.56.0",
    "prisma": "^5.9.1",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
