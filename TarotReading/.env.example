# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/tarot_dev

# Redis
REDIS_URL=redis://localhost:6379

# AI Providers (obtain from OpenAI/Anthropic)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Secrets
JWT_SECRET=your-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-32-chars-min

# External Services
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@aitarotfriend.com
LINE_CHANNEL_ACCESS_TOKEN=...
LINE_CHANNEL_SECRET=...

# Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...

# AWS / Object Storage (optional for local)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=tarot-reading-exports
KINESIS_STREAM_NAME=tarot-reading-events

# Observability (optional for local)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=tarot-reading-backend
ENABLE_TRACING=true
ENABLE_METRICS=true

# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
MOBILE_DEEP_LINK_SCHEME=aitarotfriend://

# Features
USE_MOCK_LLM=false
ENABLE_CRISIS_DETECTION=true
ENABLE_NUDGES=true
