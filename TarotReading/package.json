{
  "name": "tarot-reading",
  "version": "1.0.0",
  "description": "AI Tarot Friend - Empathetic tarot companion with memory and proactive care",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "mobile",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "migration:run": "npm run migration:run --workspace=backend",
    "migration:generate": "npm run migration:generate --workspace=backend",
    "migration:revert": "npm run migration:revert --workspace=backend",
    "seed": "npm run seed --workspace=backend",
    "db:reset": "npm run db:reset --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/TarotReading.git"
  },
  "keywords": [
    "tarot",
    "ai",
    "chatbot",
    "mental-health",
    "wellbeing"
  ],
  "author": "AI Tarot Friend Team",
  "license": "UNLICENSED"
}
